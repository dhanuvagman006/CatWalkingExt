{
  "manifest_version": 3,
  "name": "Cat Extension",
  "version": "1.0",
  "description": "Fun cat extension",

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "walking-cat.gif",
        "sleeping-cat.gif"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}